{
  "expo": {
    "name": "Skyface V2",
    "slug": "skyface-v2",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.skyface.v2",
      "infoPlist": {
        "NFCReaderUsageDescription": "This app reads NFC tags on Ghana Cards to extract identity information.",
        "NSCameraUsageDescription": "This app uses the camera to capture a selfie for identity verification.",
        "com.apple.developer.nfc.readersession.formats": ["NDEF", "TAG"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.skyface.v2",
      "versionCode": 2,
      "permissions": [
        "android.permission.NFC",
        "android.permission.CAMERA",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Skyface to access your camera for identity verification."
        }
      ]
    ]
  }
}
